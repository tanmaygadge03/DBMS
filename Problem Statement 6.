-- =========================================
-- 2: Create Function
-- Return Manager Name using Department ID
-- =========================================

DELIMITER //

CREATE FUNCTION Get_Manager_Name(d_id INT)
RETURNS VARCHAR(50)

DETERMINISTIC

BEGIN

    DECLARE m_name VARCHAR(50);

    SELECT manager_name
    INTO m_name
    FROM Department
    WHERE dept_id = d_id;

    RETURN m_name;

END //

DELIMITER ;

-- =========================================
--  : Call Function
-- =========================================

SELECT Get_Manager_Name(1) AS Manager_Name;

