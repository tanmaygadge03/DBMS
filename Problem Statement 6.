-- =========================================
-- 1 : Create Stored Procedure
-- Calculate Employee Commission
-- =========================================

DELIMITER //

CREATE PROCEDURE Calculate_Commission()
BEGIN

    -- Salary > 10000 = 0.4%
    UPDATE Employee
    SET commission = salary * 0.004
    WHERE salary > 10000;

    -- Salary < 10000 and Experience > 10 years = 0.35%
    UPDATE Employee
    SET commission = salary * 0.0035
    WHERE salary < 10000
    AND TIMESTAMPDIFF(YEAR, DoJ, CURDATE()) > 10;

    -- Salary < 3000 = 0.25%
    UPDATE Employee
    SET commission = salary * 0.0025
    WHERE salary < 3000;

    -- Remaining Employees = 0.15%
    UPDATE Employee
    SET commission = salary * 0.0015
    WHERE commission IS NULL;

END //

DELIMITER ;

-- =========================================
--  : Call Stored Procedure
-- =========================================

CALL Calculate_Commission();

