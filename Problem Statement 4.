-- =========================================
-- 2 : Make Email_Address NOT NULL
-- =========================================

ALTER TABLE Customer
MODIFY Email_Address VARCHAR(20) NOT NULL;

-- =========================================
-- 3 : Display Total Customers
-- with Balance > 50000
-- =========================================

SELECT COUNT(*) AS Total_Customers
FROM Account
WHERE Balance > 50000;

-- =========================================
-- 4 : Display Average Balance
-- for Saving Account
-- =========================================

SELECT AVG(Balance) AS Average_Balance
FROM Account
WHERE Account_type='Saving Account';

-- =========================================
-- 5 : Display Customers
-- living in Pune OR name starts with 'A'
-- =========================================

SELECT *
FROM Customer
WHERE Cust_Address='Pune'
OR Name LIKE 'A%';

-- =========================================
-- 6 : Create Saving_Account Table
-- using Account Table
-- =========================================

CREATE TABLE Saving_Account AS
SELECT Account_no,
       Branch_ID,
       CustID,
       date_open,
       Balance
FROM Account
WHERE Account_type='Saving Account';

-- =========================================
-- 7 : Display Customer Details
-- Age wise with Balance >= 20000
-- =========================================

SELECT Customer.*, Account.Balance
FROM Customer
JOIN Account
ON Customer.CustID = Account.CustID
WHERE Balance >= 20000
ORDER BY Age ASC;

