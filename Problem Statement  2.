-- =========================================
-- 1 : Create View Saving_Account
-- Open date = 16/8/2018
-- =========================================

CREATE VIEW Saving_Account AS
SELECT Customer.*, Account.open_date
FROM Customer
JOIN Account
ON Customer.CustID = Account.CustID
WHERE Account.open_date='2018-08-16';

-- Display View
SELECT * FROM Saving_Account;

-- =========================================
-- 2 : Update View
-- Change Address to Pune for CustID = 103
-- =========================================

UPDATE Customer
SET Cust_Address='Pune'
WHERE CustID=103;

-- =========================================
-- 3 : Create View Loan_Account
-- Open date = 16/2/2018
-- =========================================

CREATE VIEW Loan_Account AS
SELECT Customer.*, Account.open_date
FROM Customer
JOIN Account
ON Customer.CustID = Account.CustID
WHERE Account.open_date='2018-02-16';

-- Display View
SELECT * FROM Loan_Account;

-- =========================================
-- 4 : Create Index on Customer Primary Key
-- =========================================

CREATE INDEX idx_customer
ON Customer(CustID);

-- =========================================
-- 5 : Create Index on Branch Primary Key
-- =========================================

CREATE INDEX idx_branch
ON Branch(Branch_ID);

-- =========================================
-- 6 : Create Sequence Alternative
-- MySQL uses AUTO_INCREMENT
-- =========================================

CREATE TABLE Customer_New(
    CustID INT AUTO_INCREMENT PRIMARY KEY,
    Name VARCHAR(50),
    Cust_Address VARCHAR(100),
    Phone_no VARCHAR(15),
    Email_ID VARCHAR(50),
    Age INT
);

-- =========================================
-- 7 : Create Synonym Alternative
-- MySQL does not support SYNONYM
-- Using VIEW instead
-- =========================================

CREATE VIEW Cust_info AS
SELECT * FROM Branch;

