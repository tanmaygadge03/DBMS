-- =========================================
-- 1 : Add Column Email_Address
-- =========================================

ALTER TABLE Customer
ADD Email_Address VARCHAR(50);

-- =========================================
-- 2 : Rename Column Email_Address to Email_ID
-- =========================================

ALTER TABLE Customer
CHANGE Email_Address Email_ID VARCHAR(50);

-- =========================================
-- 3 : Display Customer with Highest Balance
-- =========================================

SELECT Customer.*, Account.Balance
FROM Customer
JOIN Account
ON Customer.CustID = Account.CustID
WHERE Balance = (
    SELECT MAX(Balance)
    FROM Account
);

-- =========================================
-- 4 : Display Customer with Lowest Balance
-- For Saving Account
-- =========================================

SELECT Customer.*, Account.Balance
FROM Customer
JOIN Account
ON Customer.CustID = Account.CustID
WHERE Account_type='Saving Account'
AND Balance = (
    SELECT MIN(Balance)
    FROM Account
    WHERE Account_type='Saving Account'
);

-- =========================================
-- 5 : Display Customer living in Pune
-- and age greater than 35
-- =========================================

SELECT *
FROM Customer
WHERE Cust_Address='Pune'
AND Age > 35;

-- =========================================
-- 6 : Display CustID, Name and Age
-- in Ascending Order of Age
-- =========================================

SELECT CustID, Name, Age
FROM Customer
ORDER BY Age ASC;

-- =========================================
-- 7 : Display Name and Branch_ID
-- Group By Account_Type
-- =========================================

SELECT Customer.Name, Account.Branch_ID, Account.Account_type
FROM Customer
JOIN Account
ON Customer.CustID = Account.CustID
GROUP BY Account.Account_type, Customer.Name, Account.Branch_ID;

